# Step 2~4에서 사용. Step 1(Mock)에서는 필요 없음.

# NewsAPI (선택, 무료 플랜 일일 100 요청 제한)
# https://newsapi.org/
NEWSAPI_KEY=

# pytrends 요청 사이 슬립(초). 비공식 API라 429 회피 목적.
PYTRENDS_SLEEP_SEC=2

# 캐시 경로
CACHE_DIR=./data/cache

# 미국·한국 종목 둘 다 다룬다. 한국 종목은 yfinance에서 .KS / .KQ 접미사 필요.
DEFAULT_REGION=US

# ─────────────────────────────────────────────────────────────
# 배포(Cloudflare) 전용 — 로컬 개발에서는 비워두면 됨.
# 셋이 모두 비어 있으면 "로컬 모드": data/ 파일을 직접 읽고 쓴다.
# ─────────────────────────────────────────────────────────────

# 데이터 레포 "owner/repo". 설정 시 "GitHub 모드"로 전환.
#   - 캐시/티커를 GitHub raw 에서 읽음
#   - 종목 추가는 GitHub API 커밋 + 워크플로 트리거
MSD_DATA_REPO=

# 코드 브랜치 (tickers.json 위치). 기본 main
MSD_DATA_REF=main

# 캐시 브랜치 (수집 결과 위치). 기본 data
MSD_CACHE_REF=data

# 종목 추가 시 tickers.json 커밋 + 워크플로 트리거에 쓰는 토큰.
# fine-grained PAT — 해당 레포의 Contents:write + Actions:write 권한.
MSD_GITHUB_TOKEN=
